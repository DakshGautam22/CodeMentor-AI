# MongoDB Configuration
# For local DB, use: mongodb://localhost:27017/codementor
# For Atlas, use: mongodb+srv://<username>:<password>@cluster.mongodb.net/codementor?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/codementor

# Security Configuration
# Generate a secret key using: openssl rand -hex 32
JWT_SECRET_KEY=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# CORS Configuration
# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:5173,https://codementor-ai.vercel.app
